    def story_namebox_callback(key):
        """The sandbox sets cur_speaker through speak(); the original story
        characters (s/m/n/y/mc) say directly, so they set it here to keep the
        per-speaker namebox art in sync."""
        def callback(event, **kwargs):
            if event == "begin":
                store.cur_speaker = key
        return callback

